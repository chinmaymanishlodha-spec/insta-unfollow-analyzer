# Copy this file to `.streamlit/secrets.toml` for local use, or paste its
# contents into the "Secrets" box in Streamlit Community Cloud (App settings ->
# Secrets). NEVER commit the real secrets.toml — it is gitignored.

# Optional shared-access password. If set, everyone must enter it to use the app.
# Leave it out / blank to make the app open to anyone with the URL.
APP_PASSWORD = "change-me-to-something-strong"
